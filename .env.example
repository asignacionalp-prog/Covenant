# Copy this to .env.local and fill in. .env.local is gitignored.

# Convex — these are auto-set by `npx convex dev` on first run.
# CONVEX_URL=https://standing-quail-556.convex.cloud
# CONVEX_DEPLOYMENT=

# Public app URL — used in magic-link emails so click-throughs land back here.
APP_URL=https://covenant.pages.dev

# PayMongo — Phase 1.3
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=

# Resend — added when email goes live.
# Without this, magic links log to Convex console (dev mode).
RESEND_API_KEY=
